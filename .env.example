# Multi-tenant API auth map: tenant:key pairs separated by commas.
# Example: AGENT_RUNTIME_API_KEYS=team-a:key-a,team-b:key-b
AGENT_RUNTIME_API_KEYS=local-dev:local-dev-key

# Background autonomous prompt enhancement loop
AUTONOMOUS_MAINTENANCE_ENABLED=true
AUTONOMOUS_MAINTENANCE_INTERVAL_SEC=1800

# Save prompt only if quality improves enough
PROMPT_QUALITY_MIN_IMPROVEMENT=2.0
PROMPT_QUALITY_MIN_SCORE=45
PROMPT_UPDATE_COOLDOWN_SEC=1800

# Optional LLM provider (OpenAI-compatible)
# AGENT_LLM_BASE_URL=https://api.openai.com/v1
# AGENT_LLM_API_KEY=replace-with-real-key
# AGENT_LLM_MODEL=gpt-4o-mini
# AGENT_LLM_TIMEOUT=45
