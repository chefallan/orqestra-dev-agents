{
  "name": "orqestra-dev-agents",
  "version": "1.0.0",
  "description": "CLI to scaffold autonomous orchestrator-driven development agents for Copilot, Claude, Codex, OpenCode, and related coding assistants.",
  "license": "MIT",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chefallan/orqestra-dev-agents.git",
    "directory": "packages/orqestra-dev-agents"
  },
  "homepage": "https://github.com/chefallan/orqestra-dev-agents/tree/main/packages/orqestra-dev-agents",
  "bugs": {
    "url": "https://github.com/chefallan/orqestra-dev-agents/issues"
  },
  "author": "chefallan <talk@itschefallan.com> (https://itschefallan.com)",
  "bin": {
    "orqestra-dev-agents": "bin/orqestra-dev-agents.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin",
    "src",
    "assets",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "copilot",
    "claude",
    "codex",
    "opencode",
    "agents",
    "developer-tools",
    "automation",
    "orchestrator"
  ],
  "scripts": {
    "start": "node bin/orqestra-dev-agents.js --help",
    "orqestra:hub": "node bin/orqestra-dev-agents.js hub",
    "orqestra:agents": "node bin/orqestra-dev-agents.js agents",
    "orqestra:workflows": "node bin/orqestra-dev-agents.js workflows",
    "orqestra:skills": "node bin/orqestra-dev-agents.js skills",
    "orqestra:tools": "node bin/orqestra-dev-agents.js tools",
    "doctor": "node bin/orqestra-dev-agents.js doctor",
    "runtime": "node bin/orqestra-dev-agents.js runtime"
  }
}
